# Mark Gradle wrap jar and images as binary to prevent corruption during Git synchronization
*.jar binary
*.png binary
*.webp binary
*.apk binary

# Ensure correct line endings for scripts and config files
gradlew text eol=lf
gradlew.bat text eol=crlf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf

